// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: incomes
// Fields:
//   - amount: number (required, > 0)
//   - date: string (required, ISO date format)
//   - notes: string (optional, max 500 chars)
//   - createdAt: timestamp (required)
//
// Collection: expenses
// Fields:
//   - amount: number (required, > 0)
//   - date: string (required, ISO date format)
//   - notes: string (optional, max 500 chars)
//   - category: string (optional, max 100 chars)
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isValidTransaction(data) {
      return data.amount is number && data.amount > 0 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 500)) &&
             (!('category' in data) || (data.category is string && data.category.size() <= 100));
    }

    match /incomes/{incomeId} {
      allow read, write: if true; // Prototype: Open for now
    }

    match /expenses/{expenseId} {
      allow read, write: if true; // Prototype: Open for now
    }
  }
}
